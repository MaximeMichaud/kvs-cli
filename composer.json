{
    "name": "kvs/cli",
    "description": "Command-line interface for KVS (Kernel Video Sharing) CMS",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": ">=8.1",
        "symfony/console": "^6.4",
        "symfony/process": "^6.4",
        "symfony/filesystem": "^6.4",
        "symfony/finder": "^6.4",
        "symfony/yaml": "^6.4",
        "symfony/string": "^6.4",
        "symfony/var-dumper": "^6.4",
        "psy/psysh": "^0.12"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5",
        "phpstan/phpstan": "^1.12 || ^2.0",
        "phpstan/phpstan-symfony": "^1.4 || ^2.0",
        "phpstan/phpstan-strict-rules": "^1.6 || ^2.0",
        "squizlabs/php_codesniffer": "^3.8 || ^4.0",
        "mikey179/vfsstream": "^1.6",
        "editorconfig-checker/editorconfig-checker": "^10.6",
        "seld/jsonlint": "^1.11"
    },
    "autoload": {
        "psr-4": {
            "KVS\\CLI\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "KVS\\CLI\\Tests\\": "tests/"
        }
    },
    "bin": [
        "bin/kvs"
    ],
    "scripts": {
        "prepare": "@php -r \"if (!getenv('CI')) { $r = null; exec('lefthook install 2>&1', $o, $r); if ($r !== 0) { fwrite(STDERR, implode(PHP_EOL, $o) . PHP_EOL); exit($r); } }\"",
        "build": "php -d phar.readonly=0 build.php",
        "test": "phpunit --configuration phpunit.xml.dist",
        "test-unit": "phpunit --configuration phpunit.xml.dist --testsuite=\"Unit Tests\"",
        "test-integration": "phpunit --configuration phpunit.xml.dist --testsuite=\"Integration Tests\"",
        "test-functional": "phpunit --configuration phpunit.xml.dist --testsuite=\"Functional Tests\"",
        "coverage": "XDEBUG_MODE=coverage phpunit --configuration phpunit.xml.dist --coverage-text",
        "coverage-html": "XDEBUG_MODE=coverage phpunit --configuration phpunit.xml.dist --coverage-html coverage-report",
        "phpcs": "phpcs --standard=phpcs.xml",
        "phpcbf": "phpcbf --standard=phpcs.xml",
        "phpstan": "phpstan analyse --memory-limit=512M",
        "phpstan-baseline": "phpstan analyse --generate-baseline --memory-limit=512M",
        "analyse": "@phpstan",
        "lint": [
            "@phpcs",
            "@phpstan"
        ],
        "lint-fix": "@phpcbf",
        "check": [
            "@lint",
            "@test"
        ],
        "check-all": [
            "@phpcs",
            "@phpstan",
            "@test",
            "@coverage"
        ],
        "test-cli": "@php tests/test-cli.php",
        "test-all": ["@test-cli", "@test"]
    },
    "config": {
        "platform": {
            "php": "8.1.0"
        }
    }
}
