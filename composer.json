{
    "name": "kvs/cli",
    "description": "Command-line interface for KVS (Kernel Video Sharing) CMS",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": ">=8.1",
        "symfony/console": "^6.4",
        "symfony/process": "^6.4",
        "symfony/filesystem": "^6.4",
        "symfony/finder": "^6.4",
        "symfony/yaml": "^6.4",
        "symfony/string": "^6.4",
        "symfony/var-dumper": "^6.4",
        "psy/psysh": "^0.12"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "phpstan/phpstan": "^1.10",
        "phpstan/phpstan-symfony": "^1.3",
        "phpstan/phpstan-strict-rules": "^1.5",
        "squizlabs/php_codesniffer": "^4.0",
        "mikey179/vfsstream": "^1.6"
    },
    "autoload": {
        "psr-4": {
            "KVS\\CLI\\": "src/"
        }
    },
    "bin": [
        "bin/kvs"
    ],
    "scripts": {
        "build": "php -d phar.readonly=0 build.php",
        "test": "phpunit",
        "test-unit": "phpunit --testsuite=\"Unit Tests\"",
        "test-integration": "phpunit --testsuite=\"Integration Tests\"",
        "test-functional": "phpunit --testsuite=\"Functional Tests\"",
        "coverage": "XDEBUG_MODE=coverage phpunit --coverage-text",
        "coverage-html": "XDEBUG_MODE=coverage phpunit --coverage-html coverage-report",
        "phpcs": "phpcs --standard=phpcs.xml",
        "phpcbf": "phpcbf --standard=phpcs.xml",
        "phpstan": "phpstan analyse --memory-limit=512M",
        "phpstan-baseline": "phpstan analyse --generate-baseline --memory-limit=512M",
        "analyse": "@phpstan",
        "lint": [
            "@phpcs",
            "@phpstan"
        ],
        "lint-fix": "@phpcbf",
        "check": [
            "@lint",
            "@test"
        ],
        "check-all": [
            "@phpcs",
            "@phpstan",
            "@test",
            "@coverage"
        ],
        "test-cli": "@php tests/test-cli.php",
        "test-all": ["@test-cli", "@test"]
    }
}
