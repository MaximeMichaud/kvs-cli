# PHPStan configuration for KVS CLI
# Target: Level 8 (gradually moving to 9)
# https://phpstan.org/config-reference

parameters:
    # Analysis level (0-10, with 10 being strictest in PHPStan 2.x)
    # Level 9: strict mixed types, dead code detection
    level: 9

    # Parallel processing for faster analysis
    parallel:
        maximumNumberOfProcesses: 4
        processTimeout: 60.0

    # Paths to analyze
    paths:
        - src

    # Directories to exclude
    excludePaths:
        - src/Bootstrap/legacy_*.php
        - vendor

    # Check for uninitialized properties
    checkUninitializedProperties: true

    # Report unmatched ignored errors
    reportUnmatchedIgnoredErrors: false

    # Symfony Console type inference
    symfony:
        consoleApplicationLoader: phpstan-console.php

includes:
    # Baseline for existing errors (temporary)
    - phpstan-baseline.neon
    # Include Symfony extensions when available
    - vendor/phpstan/phpstan-symfony/extension.neon
    - vendor/phpstan/phpstan-strict-rules/rules.neon

# Roadmap:
# Level 5 -> Fix obvious issues (done)
# Level 6 -> Add strict types, fix mixed types (done)
# Level 7 -> Remove implicit mixed (done)
# Level 8 -> Production-ready strict mode (done)
# Level 9 -> Strict mixed types + dead code (done - current, 419 in baseline)
# Level 10 -> Maximum strictness (PHPStan 2.x)
